<?xml version="1.0" encoding="utf-8"?>
<!--
  mmhue is a plain-HTTP panel on the home LAN, and the address is now a
  user setting, so the app must allow cleartext to whatever host the user
  points it at. Cleartext is permitted app-wide for that reason. If mmhue is
  ever exposed beyond the LAN it should move to HTTPS and this should tighten.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
